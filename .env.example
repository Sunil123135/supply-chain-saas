# =============================================================================
# Yugam — MASTER ENV TEMPLATE (fill in, then copy sections to each place)
# =============================================================================
#
# WHERE EACH VARIABLE GOES:
#
#   apps/web/.env.local     → local Next.js dev (copy FRONTEND section)
#   .env.netlify            → Netlify import (FRONTEND only — NEXT_PUBLIC_*)
#   backend/.env.backend    → local FastAPI dev (copy BACKEND section)
#   .env.railway            → Railway variables (BACKEND section)
#
# NEVER commit files with real secrets (.env.local, .env.backend, filled .env.netlify)
# =============================================================================

# ─── FRONTEND (Netlify + apps/web/.env.local) ───────────────────────────────
NEXT_PUBLIC_APP_NAME=Yugam
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production: set NEXT_PUBLIC_API_URL to your Railway URL, e.g.
# NEXT_PUBLIC_API_URL=https://YOUR_SERVICE.up.railway.app

# ─── BACKEND (Railway + backend/.env.backend) — NOT for Netlify ─────────────
OPENROUTER_API_KEY=sk-or-v1-YOUR_OPENROUTER_KEY
OPENROUTER_MODEL=openai/gpt-4-turbo
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_SECRET=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SERVICE_ROLE_KEY
APP_URL=http://localhost:3000
ENVIRONMENT=development
DEBUG=true

# ─── WHERE TO GET VALUES ─────────────────────────────────────────────────────
# Supabase URL + anon + service_role → https://supabase.com/dashboard → Project → Settings → API
# OpenRouter key                     → https://openrouter.ai/keys
# Railway URL                        → Railway service → Settings → Networking → Public domain
# Netlify URL                        → Netlify site → Domain overview
