NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Railway backend (local: http://localhost:8000)
NEXT_PUBLIC_API_URL=http://localhost:8000

# OpenRouter is server-side only — set on Railway backend, not in browser for production
# NEXT_PUBLIC_OPENROUTER_API_KEY=  # avoid exposing in client; use backend /api/copilot

NEXT_PUBLIC_APP_NAME=Yugam
