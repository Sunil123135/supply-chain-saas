# =============================================================================
# NETLIFY ONLY — copy to .env.netlify, fill values, import in Netlify UI
# Site settings → Environment variables → Import from .env
# Then trigger Deploy → Deploy site (NEXT_PUBLIC_* are baked at build time)
# =============================================================================
#
# ⚠️  Only NEXT_PUBLIC_* here. Never OPENROUTER_API_KEY or service role keys.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Railway PUBLIC domain — must end with .up.railway.app (NOT railway.com/project/...)
NEXT_PUBLIC_API_URL=https://YOUR_SERVICE.up.railway.app

# Yugam Optimizer (forecasting) — separate Railway service
OPTIMIZER_URL=https://YOUR_OPTIMIZER.up.railway.app

NEXT_PUBLIC_APP_NAME=Yugam

# Optional — seed API (server-side on Netlify functions)
# SEED_SECRET=generate_a_long_random_string
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
