# Copy to .env.local (same folder) — NEVER commit .env.local
#
#   copy .env.local.example .env.local
#
# For production, Netlify uses the same variable NAMES (import via .env.netlify).

NEXT_PUBLIC_APP_NAME=Yugam
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY
NEXT_PUBLIC_API_URL=http://localhost:8000
OPTIMIZER_URL=http://localhost:8001

# Bots + autonomy
BOT_SHARED_SECRET=change-me
BOT_OPEN_DEMO=true
VPS_WEBHOOK_SECRET=change-me
WHATSAPP_VERIFY_TOKEN=change-me

# Dify RAG — LOCAL tunnel only (ssh -L 8082:127.0.0.1:8082 root@VPS)
# Accepts with or without trailing /v1
DIFY_API_URL=http://127.0.0.1:8082
DIFY_API_KEY=app-YOUR_KEY
DIFY_USER=yugam-sarvam
#
# PRODUCTION (Netlify): use public Dokploy HTTPS, never 127.0.0.1
# DIFY_API_URL=https://dify.YOUR-DOMAIN
