# Copy to .env next to docker-compose.yml
#
# Local Next.js (Docker Desktop):
#   YUGAM_URL=http://host.docker.internal:3000
# Production Netlify (after deploy that includes /api/autonomy/run):
YUGAM_URL=https://sctransformation.netlify.app
VPS_WEBHOOK_SECRET=change-me-to-match-netlify
BOT_OPEN_DEMO=true
YUGAM_INDUSTRY=medtech
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=yugam-autonomy
# Corporate SSL inspection (local Docker → Netlify): set false if cert verify fails
YUGAM_SSL_VERIFY=false
